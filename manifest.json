  {cod:"S92.3",desc:"Fratura do cuboide"},
  {cod:"S92.4",desc:"Fratura de metatarso"},
  {cod:"S92.5",desc:"Fratura de falange do pé"},
  {cod:"M19.07",desc:"Artrose primária do tornozelo"},
