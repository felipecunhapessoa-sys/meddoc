const PROC_DB = [
  {cod:"31201017",desc:"Correção de hallux valgus — osteotomia"},
  {cod:"31201025",desc:"Osteotomia do calcâneo"},
  {cod:"31201033",desc:"Artrodese articulação metatarsofalângica"},
  {cod:"31201041",desc:"Artrodese tíbio-talar"},
  {cod:"31201050",desc:"Artrodese talonavicular"},
  {cod:"31201068",desc:"Artrodese subtalar"},
  {cod:"31201076",desc:"Artrodese tripla"},
  {cod:"31201084",desc:"Osteotomia de metatarso — percutânea"},
  {cod:"31201092",desc:"Tratamento cirúrgico fratura do calcâneo"},
  {cod:"31201106",desc:"Tratamento cirúrgico fratura do astrágalo"},
  {cod:"31201114",desc:"Tratamento cirúrgico fratura de metatarso"},
  {cod:"31201122",desc:"Reconstrução ligamentar do tornozelo"},
  {cod:"31201130",desc:"Reparo do tendão de Aquiles — sutura primária"},
  {cod:"31201149",desc:"Reparo do tendão de Aquiles — com reforço"},
  {cod:"31201157",desc:"Liberação do túnel do tarso"},
  {cod:"31201165",desc:"Fasciotomia plantar"},
  {cod:"31201173",desc:"Ressecção de esporão do calcâneo"},
  {cod:"31201181",desc:"Artroscopia do tornozelo — diagnóstica"},
  {cod:"31201190",desc:"Artroscopia do tornozelo — com procedimento"},
  {cod:"31201203",desc:"Tenossinovectomia do tornozelo"},
