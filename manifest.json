  {cod:"31201220",desc:"Correção de dedo em martelo"},
  {cod:"31201238",desc:"Liberação de fáscia plantar — endoscópica"},
  {cod:"40801020",desc:"Amputação transmetatarsiana"},
];

const EXAM_DB = [
  {cod:"40901013",desc:"Radiografia do pé — AP e perfil"},
  {cod:"40901021",desc:"Radiografia do tornozelo — AP, perfil e oblíqua"},
  {cod:"40901030",desc:"Radiografia em carga bilateral dos pés"},
  {cod:"40906017",desc:"Ressonância magnética do tornozelo"},
  {cod:"40906025",desc:"Ressonância magnética do pé"},
  {cod:"40905012",desc:"Tomografia computadorizada do tornozelo"},
  {cod:"40905020",desc:"Tomografia computadorizada do pé"},
  {cod:"40301234",desc:"Cintilografia óssea"},
  {cod:"40801056",desc:"Densitometria óssea"},
  {cod:"40302056",desc:"Eletroneuromiografia membros inferiores"},
  {cod:"40201010",desc:"Hemograma completo"},
  {cod:"40202040",desc:"Proteína C-reativa (PCR)"},
  {cod:"40202088",desc:"VHS (velocidade de hemossedimentação)"},
  {cod:"40901056",desc:"Radiografia simples — coluna lombar"},
  {cod:"40906033",desc:"Ressonância magnética — coluna lombar"},
];

// --- UTILS ---
function $(id){ return document.getElementById(id) }
function toast(msg){
  const t=$('toast'); t.textContent=msg; t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'),2500);
}

// Greeting
(function(){
  const h = new Date().getHours();
  const g = h<12?'Bom dia':h<18?'Boa tarde':'Boa noite';
  $('home-greeting').textContent = g+', Dr. Felipe 👋';
})();

// Tab navigation
function goTab(id){
  document.querySelectorAll('.tab').forEach((t,i)=>{
    const ids=['home','cirurgia','urgencia','exame','perfil'];
    t.classList.toggle('active',ids[i]===id);
  });
  document.querySelectorAll('.section').forEach(s=>s.classList.remove('active'));
  $('tab-'+id).classList.add('active');
  window.scrollTo(0,0);
}

// Search
function searchDB(db,q,ddId,tagsId){
  const dd=$(ddId);
  if(!q||q.length<2){dd.classList.remove('open');return;}
  const r=db.filter(i=>i.desc.toLowerCase().includes(q.toLowerCase())||i.cod.includes(q)).slice(0,8);
  if(!r.length){dd.classList.remove('open');return;}
  dd.innerHTML=r.map(i=>`<div class="dd-item" data-cod="${i.cod}" data-desc="${i.desc}"><div>${i.cod}</div><div class="dd-item-sub">${i.desc}</div></div>`).join('');
  dd.classList.add('open');
  dd.querySelectorAll('.dd-item').forEach(el=>{
    el.onclick=()=>{ addTag(tagsId,el.dataset.cod,el.dataset.desc); dd.classList.remove('open'); };
  });
}

function addTag(tagsId,cod,desc){
  const wrap=$(tagsId);
  if(wrap.querySelector(`[data-cod="${cod}"]`)) return;
  const t=document.createElement('span');
  t.className='tag'; t.dataset.cod=cod;
  t.innerHTML=`<strong>${cod}</strong>&nbsp;${desc}<button onclick="this.parentElement.remove()" aria-label="Remover">×</button>`;
  wrap.appendChild(t);
}

document.addEventListener('click',e=>{
  if(!e.target.closest('.search-wrap')&&!e.target.closest('.dropdown'))
    document.querySelectorAll('.dropdown').forEach(d=>d.classList.remove('open'));
});

function getTags(id){
  return Array.from(document.querySelectorAll(`#${id} .tag`)).map(t=>`${t.dataset.cod} — ${t.querySelector('strong').nextSibling.textContent.trim()}`);
}

// API Key
function getKey(){
  return localStorage.getItem('meddoc_apikey')||'';
}
function salvarKey(){
  const k=$('api-key').value.trim();
  if(!k){toast('Cole a chave antes de salvar');return;}
  localStorage.setItem('meddoc_apikey',k);
  toast('Chave salva com segurança ✓');
}
window.addEventListener('load',()=>{
  const k=getKey();
  if(k) $('api-key').value=k;
  renderFavs();
});

// Perfil
function salvarPerfil(){
  toast('Perfil salvo ✓');
}

// Favoritos
function getFavs(){ try{return JSON.parse(localStorage.getItem('meddoc_favs')||'[]')}catch{return[]} }
function saveFavs(f){ localStorage.setItem('meddoc_favs',JSON.stringify(f)) }
function renderFavs(){
  const favs=getFavs();
  const el=$('favs-list');
  if(!favs.length){el.innerHTML='<p style="font-size:13px;color:var(--muted)">Nenhum favorito ainda.</p>';return;}
  el.innerHTML=favs.map((f,i)=>`<div class="fav-item"><div><div class="fav-name">${f.desc}</div><div class="fav-cod">${f.cod}</div></div><button class="fav-del" onclick="removeFav(${i})" aria-label="Remover"><i class="ti ti-trash" aria-hidden="true"></i></button></div>`).join('');
}
function removeFav(i){ const f=getFavs(); f.splice(i,1); saveFavs(f); renderFavs(); }

// Gerar documento
async function gerar(tipo){

  const medico='Dr. Felipe Cunha Pessôa, CRM DF 19457, Especialista em Ortopedia e Traumatologia — Pé e Tornozelo, Brasília-DF';
  let prompt='';

  if(tipo==='cirurgia'){
    const nome=$('pac-nome').value||'(não informado)';
    const nasc=$('pac-nasc').value;
    const conv=$('pac-convenio').value;
    const cart=$('pac-carteirinha').value;
    const cids=getTags('cid-tags').join('; ')||'(não informado)';
    const procs=getTags('proc-tags').join('; ')||'(não informado)';
    const indic=$('cir-indicacao').value||'(não informado)';
    const carat=$('cir-carater').value;
    const via=$('cir-via').value;
    const mat=$('cir-material').value;
    prompt=`Gere um pedido de autorização de cirurgia formal e completo para convênio médico, em português brasileiro.

Médico solicitante: ${medico}
Paciente: ${nome}${nasc?` | Nasc: ${nasc}`:''}
Convênio: ${conv}${cart?` | Carteirinha: ${cart}`:''}
Diagnóstico (CID-10): ${cids}
Procedimentos (CBHPM 2018): ${procs}
Caráter: ${carat} | Via: ${via}
Indicação clínica: ${indic}
Material/implante: ${mat||'não especificado'}

Formate como documento médico oficial: cabeçalho completo, dados do paciente, diagnóstico com CID, procedimentos com códigos CBHPM, indicação clínica detalhada, local/data e assinatura do médico. Tom formal, linguagem técnica.`;
  } else if(tipo==='urgencia'){
    const nome=$('urg-nome').value||'(não informado)';
    const conv=$('urg-convenio').value;
    const dt=$('urg-data').value;
    const trauma=$('urg-trauma').value||'(não informado)';
    const cids=getTags('tags-cid-urg').join('; ')||'(não informado)';
    const procs=getTags('tags-proc-urg').join('; ')||'(não informado)';
    const anest=$('urg-anest').value;
    const pos=$('urg-posicao').value;
    const desc=$('urg-descricao').value||'(não informado)';
    const conduta=$('urg-conduta').value;
    prompt=`Gere um relatório de cirurgia de urgência formal e completo para convênio médico, em português brasileiro.

Médico responsável: ${medico}
Paciente: ${nome} | Convênio: ${conv}${dt?` | Atendimento: ${dt}`:''}
Diagnóstico (CID-10): ${cids}
Mecanismo / queixa: ${trauma}
Procedimento realizado (CBHPM): ${procs}
Anestesia: ${anest} | Posição: ${pos}
Descrição cirúrgica: ${desc}
Conduta pós-operatória: ${conduta||'a definir'}

Formate como relatório cirúrgico oficial com todos os campos padrão exigidos por convênios. Tom formal, linguagem técnica cirúrgica.`;
  } else {
    const nome=$('ex-nome').value||'(não informado)';
    const conv=$('ex-convenio').value;
    const exames=getTags('exam-tags').join('; ')||'(não informado)';
    const cids=getTags('tags-cid-ex').join('; ')||'(não informado)';
    const justif=$('ex-justificativa').value;
    prompt=`Gere um pedido de exames médicos formal e completo para convênio, em português brasileiro.

Médico solicitante: ${medico}
Paciente: ${nome} | Convênio: ${conv}
Exames solicitados (com códigos): ${exames}
Hipótese diagnóstica (CID-10): ${cids}
Justificativa clínica: ${justif||'(gerar automaticamente com base nos dados fornecidos, com linguagem adequada para aprovação pelo convênio)'}

Formate como solicitação médica oficial com cabeçalho, dados do paciente, lista de exames com códigos, justificativa clínica detalhada, data e assinatura.`;
  }

  const outId='out-'+tipo;
  $(outId).innerHTML=`<div class="loading"><div class="dot"></div><div class="dot"></div><div class="dot"></div><span>Gerando documento com IA…</span></div>`;

  try {
    const res=await fetch('/api/gerar',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({prompt})
    });
    const data=await res.json();
    if(data.error){$(outId).innerHTML=`<div class="output-box">Erro: ${data.error}</div>`;return;}
    const txt=data.text||'Erro ao gerar.';
    $(outId).innerHTML=`<div class="output-wrap"><div class="output-header"><span class="output-label">Documento gerado</span><button class="btn-secondary" style="padding:8px 14px;font-size:12px" onclick="copiar('doc-${tipo}')"><i class='ti ti-copy' aria-hidden='true'></i> Copiar</button></div><div class="output-box" id="doc-${tipo}">${txt.replace(/&/g,'&amp;').replace(/</g,'&lt;')}</div></div>`;
  } catch(e){
    $(outId).innerHTML=`<div class="output-box">Erro de conexão. Tente novamente.</div>`;
  }
}

function copiar(id){
  const txt=$(id)?.innerText||'';
  navigator.clipboard.writeText(txt).then(()=>toast('Copiado ✓'));
}

function limpar(tipo){
  const campos={
    cirurgia:['pac-nome','pac-carteirinha','cir-indicacao','cir-material'],
    urgencia:['urg-nome','urg-trauma','urg-descricao','urg-conduta'],
    exame:['ex-nome','ex-justificativa']
  };
  (campos[tipo]||[]).forEach(id=>{const el=$(id);if(el)el.value='';});
  const tagAreas={
    cirurgia:['cid-tags','proc-tags'],
    urgencia:['tags-cid-urg','tags-proc-urg'],
    exame:['exam-tags','tags-cid-ex']
  };
  (tagAreas[tipo]||[]).forEach(id=>{const el=$(id);if(el)el.innerHTML='';});
  $('out-'+tipo).innerHTML='';
}

// Service Worker
if('serviceWorker' in navigator){
  navigator.serviceWorker.register('sw.js').catch(()=>{});
}
</script>
</body>
</html>
